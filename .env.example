# 운영 환경 (.env.production)
# NUXT_PUBLIC_API_BASE=https://api.didit.ai.kr

# 소셜 로그인 키
NUXT_PUBLIC_KAKAO_JS_KEY=카카오_JavaScript_키
NUXT_PUBLIC_KAKAO_REST_KEY=카카오_REST_API_키
